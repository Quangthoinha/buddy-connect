# =====================================================================
# Mini-app env — copy file này sang `.env` rồi điền giá trị
# =====================================================================

# --- App identity ---
VITE_APP_SLUG=demo                  # slug của mini-app, bất biến. Quyết định:
                                    #   - schema:  app_{slug} + app_{slug}_dev
                                    #   - bucket:  miniapp-{slug}
                                    #   - prod domain: {slug}.mini.mushy-app.com
                                    # 3-41 ký tự [a-z0-9-], unique trong catalog Mushy.
VITE_APP_ENV=dev                    # 'prod' | 'dev'. Local DEV mặc định 'dev' → hit schema app_{slug}_dev.
                                    # Vercel: Production scope = 'prod', Preview scope = 'dev'.

# --- Optional: storage backend ---
# VITE_USE_R2=true                  # Bật R2 (qua Edge Function), default Supabase Storage

# --- Supabase (client-side, public) ---
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# --- Dev fake context (chỉ dùng khi chạy localhost) ---
# scripts/setup.js sẽ tự ghi 4 biến dưới đây sau khi login + tạo workspace
VITE_DEV_TOKEN=
VITE_DEV_WORKSPACE_ID=
VITE_DEV_USER_ID=
VITE_DEV_ROLE=admin

# =====================================================================
# Server-side (Vercel env vars) — KHÔNG prefix VITE_
# Chỉ set trên Vercel dashboard, KHÔNG commit, KHÔNG đọc từ client.
#
# Set per scope (Production + Preview), giá trị giống nhau (vì Mushy 1 Supabase):
# =====================================================================

# SUPABASE_URL=                     # cùng VITE_SUPABASE_URL, dùng cho api/_verify
# SUPABASE_SERVICE_ROLE_KEY=        # service_role key, bypass RLS — chỉ server-side
#
# AI provider keys (chọn 1 hoặc nhiều, tùy mini-app dùng):
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
#
# R2 (nếu VITE_USE_R2=true):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=miniapp-{slug}
