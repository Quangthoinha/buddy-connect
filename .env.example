# =====================================================================
# Mini-app env — copy file này sang `.env` rồi điền giá trị (chỉ DEV-related).
#
# ⚠️ Slug, Supabase URL, anon key giờ ở `mushy.config.json` (committed).
# .env CHỈ chứa giá trị secret hoặc dev-only (KHÔNG commit).
# =====================================================================

# --- Vercel-only env (KHÔNG cần set local, chỉ Vercel Dashboard) ---
# VITE_APP_ENV=prod                # Production scope: 'prod', Preview scope: 'dev'
#                                  # Local DEV mặc định 'dev' (xem .env hoặc env shell)

# --- Local DEV ENV (chỉ chạy localhost) ---
# Mặc định DEV → schema app_{slug}_dev. Set =prod nếu muốn test prod schema local.
VITE_APP_ENV=dev

# (Optional) Storage backend
# VITE_USE_R2=true                 # Bật R2 thay Supabase Storage (cần Edge Functions setup)

# --- Dev fake context (chỉ dùng khi chạy localhost browser, không có Shell inject) ---
# scripts/setup.js sẽ tự ghi 4 biến dưới đây sau khi login + tạo workspace
VITE_DEV_TOKEN=
VITE_DEV_WORKSPACE_ID=
VITE_DEV_USER_ID=
VITE_DEV_ROLE=admin

# =====================================================================
# Server-side (Vercel env vars) — KHÔNG prefix VITE_, KHÔNG commit
# Set trên Vercel Dashboard cho project mini-app:
# =====================================================================

# SUPABASE_URL=                    # Lặp lại URL từ mushy.config.json (api/_verify.js dùng)
# SUPABASE_SERVICE_ROLE_KEY=       # service_role key — TUYỆT ĐỐI không cho vào mushy.config.json

# AI provider keys (per mini-app, do dev tự cấp khi cần feature AI):
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=

# R2 (nếu VITE_USE_R2=true):
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=miniapp-{slug}
